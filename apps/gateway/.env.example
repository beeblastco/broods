# Comma-separated core HTTP origins that serve the runtime API (tried in order).
BROODS_CORE_URLS=https://core.example.com

# Convex HTTP-actions origin (…convex.site) serving the config plane
# (/v1/account GET/PATCH/rotate, /accounts admin GET/PATCH/rotate,
# /v1/skills, /v1/tools, /v1/workspaces/{id}/files, /v1/crons,
# /v1/workspaces, /v1/sandboxes CRUD, /v1/policies). Signup/delete stay core.
# Unset → those routes 503.
BROODS_CONFIG_URL=https://your-deployment.convex.site

# In-cluster gateway deployments should use nats://nats.nats.svc.cluster.local:4222.
# Local/out-of-cluster runs can use wss://nats.beeblast.co.
NATS_URL=nats://nats.nats.svc.cluster.local:4222
# NATS_TOKEN=

# Local/container bind settings.
PORT=3000
HOSTNAME=0.0.0.0

# Per-pod guardrails. Keep the gateway stateless and scale with replicas.
GATEWAY_MAX_CONNECTIONS=10000
GATEWAY_MAX_PAYLOAD_BYTES=1048576
GATEWAY_BACKPRESSURE_BYTES=1048576
GATEWAY_IDLE_TIMEOUT_SECONDS=300
GATEWAY_RUN_START_TIMEOUT_MS=15000

# WebSocket origin allow-list (browser upgrades only; SDK/CLI send no Origin).
# Comma-separated hostnames, exact or wildcard suffix. Default:
# broods.app, *.broods.app, localhost, 127.0.0.1. "*" disables the check.
# GATEWAY_ALLOWED_ORIGINS=broods.app,*.broods.app,localhost,127.0.0.1

# Per-IP fixed-window rate limits (per pod). Upgrade attempts bound connection
# churn; auth failures bound token brute force and are checked before the core
# auth roundtrip.
GATEWAY_UPGRADES_PER_MINUTE=120
GATEWAY_AUTH_FAILURES_PER_MINUTE=20
