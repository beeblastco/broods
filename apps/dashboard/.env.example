# Convex deployment the app connects to (the convex CLI itself runs from
# packages/convex with its own .env.local).
NEXT_PUBLIC_CONVEX_URL=
# Optional: override the derived *.convex.site URL used by the CLI proxy route.
# CONVEX_SITE_URL=

# WorkOS AuthKit (read by @workos-inc/authkit-nextjs).
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=
WORKOS_COOKIE_PASSWORD=

# Agent platform endpoints.
NEXT_PUBLIC_AGENT_GATEWAY_URL=
# Optional: shown in the org settings API access panel.
# NEXT_PUBLIC_BROODS_HARNESS_URL=
