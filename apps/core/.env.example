# Local SST CLI settings.
# SST loads `.env` into `process.env` for `sst.config.ts`.
AWS_PROFILE=default
SST_STAGE=dev
AWS_REGION=us-east-1

# Required for deploy: your AWS account ID and project metadata.
# These are read by sst.config.ts and used for ECR repo names, IAM role ARNs, and tags.
AWS_ACCOUNT_ID=123456789012
PROJECT_NAME=broods
PROJECT_OWNER_EMAIL=owner@example.com

# Deploy inputs are plain environment variables read directly by sst.config.ts
# (no SST secret store). CI injects them from GitHub Actions secrets; for local
# deploys set them here (this file is gitignored) or export them in your shell.
#   SERVICE_AUTH_SECRET=<long-random-value>              # required; trusted service token and cron API destination auth
#   PUBLIC_BASE_URL=https://gateway.example.com          # required for SST deploy cron target; use localhost for local serve
# Runtime secrets (ADMIN_ACCOUNT_SECRET, ACCOUNT_CONFIG_ENCRYPTION_SECRET, ...)
# are container env now — the k8s release files in the infra repo and the Convex
# deployment env carry them; sst.config.ts no longer reads them.
# NOTE: ACCOUNT_CONFIG_ENCRYPTION_SECRET must match the value used to encrypt the
# existing account config / sandbox credentials in Convex — changing it makes that
# stored data undecryptable.
# The configure-* account scripts also read ADMIN_ACCOUNT_SECRET.

# Manual Discord slash command sync (scripts/discord-sync.ts).
# DISCORD_APPLICATION_ID=your-discord-application-id
# DISCORD_SYNC_GUILD_ID=your-development-guild-id
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Channel configure-* script inputs (TELEGRAM_*, SLACK_*, GITHUB_*, ...) are
# normally provided through GitHub Actions secrets for CI/CD. For local runs,
# export them in your shell or add them here.

# Daytona sandbox defaults read by scripts/daytona-s3-snapshot.ts and the
# container runtime (the Daytona SDK reads DAYTONA_API_KEY implicitly).
# DAYTONA_ORGANIZATION_ID=
# DAYTONA_API_KEY=
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_S3_SNAPSHOT_NAME=fuse-s3
# DAYTONA_S3_SNAPSHOT_BASE_IMAGE=daytonaio/sandbox:0.8.0

# Mock webhook subscription secret for testing inbound webhooks.
# CI/CD uses the MOCK_WEBHOOK_SECRET GitHub secret.
#   MOCK_WEBHOOK_SECRET=<long-random-value>

# NATS (WebSocket transport + JetStream) for the WebSocket gateway path.
# Required when ENABLE_WEBSOCKET=true. CI/CD uses the NATS_URL / NATS_TOKEN secrets.
# Use the wss:// endpoint (core 4222 is cluster-internal); omit NATS_TOKEN for an
# unauthenticated server.
#   NATS_URL=wss://nats.beeblast.co
#   NATS_TOKEN=<token>

# Optional OPA policy decision endpoint for agent runtime authorization.
# Lambdas run outside the cluster, so point at the exposed endpoint (CI/CD uses
# the OPA_BASE_URL variable + OPA_API_TOKEN secret); localhost only works for a
# locally running OPA.
#   OPA_BASE_URL=https://opa.beeblast.co
#   OPA_API_TOKEN=<token>
#   OPA_BASE_URL=http://127.0.0.1:8181

# Self-hosted container runtime (src/server.ts, epic #85). This is the ONLY
# runtime — core no longer runs on Lambda. In the cluster the k8s release files
# in the infra repo set these; for a LOCAL run (`bun run serve`) set them here.
#   PORT=3000
#   PUBLIC_BASE_URL=http://localhost:3000              # base URL for callbacks + status; required by SST deploys too
#   SERVICE_NAME=dev-broods-core-pod                   # logs/traces service name
#   BROODS_CONTAINER_RUNTIME=1                         # marks a deployed runtime (prewarm gate); LEAVE UNSET for local
#   REQUEST_TIMEOUT_BUDGET_MS=600000                   # per-request work deadline
#   WORKER_TIMEOUT_BUDGET_MS=600000                    # in-process async worker deadline
#   MAX_INPROCESS_WORKERS=8                            # in-process async worker concurrency cap
#
# Run the core locally against the real dev backend:
#   1. Fill the AWS creds + table/bucket names + secrets above (copy from the dev
#      stack outputs / your CI secrets; ACCOUNT_CONFIG_ENCRYPTION_SECRET must match
#      the value that encrypted the stored Convex config or reads fail to decrypt).
#   2. `bun run serve`  (serves on http://localhost:3000, path-routed, no Host needed)
#   3. Point the demos at it: set BROODS_BASE_URL=http://localhost:3000 in the demo
#      env (see packages/demos/.env.example) and run the demo from its folder.

# Demo scripts read their own env from `packages/demos/.env` — see
# `packages/demos/.env.example`.
