# Local SST CLI settings.
# SST loads `.env` into `process.env` for `sst.config.ts`.
AWS_PROFILE=default
SST_STAGE=dev
AWS_REGION=us-east-1

# Required for deploy: your AWS account ID and project metadata.
# These are read by sst.config.ts and used for ECR repo names, IAM role ARNs, and tags.
AWS_ACCOUNT_ID=123456789012
PROJECT_NAME=broods
PROJECT_OWNER_EMAIL=owner@example.com

# Deploy secrets are plain environment variables read directly by sst.config.ts
# (no SST secret store). CI injects them from GitHub Actions secrets; for local
# deploys set them here (this file is gitignored) or export them in your shell.
# NOTE: ACCOUNT_CONFIG_ENCRYPTION_SECRET must match the value used to encrypt the
# existing account config / sandbox credentials in Convex — changing it makes that
# stored data undecryptable.
#   ADMIN_ACCOUNT_SECRET=<long-random-value>
#   ACCOUNT_CONFIG_ENCRYPTION_SECRET=<long-random-value>
#   SERVICE_AUTH_SECRET=<optional; trusted server-side caller token>
# The configure-* account scripts also read ADMIN_ACCOUNT_SECRET. They resolve the
# service URLs from the local `.sst/` deploy outputs; set ACCOUNT_SERVICE_URL /
# AGENT_SERVICE_URL only to override them.

# Manual Discord slash command sync (scripts/discord-sync.ts).
# DISCORD_APPLICATION_ID=your-discord-application-id
# DISCORD_SYNC_GUILD_ID=your-development-guild-id
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Channel configure-* script inputs (TELEGRAM_*, SLACK_*, GITHUB_*, ...) are
# normally provided through GitHub Actions secrets for CI/CD. For local runs,
# export them in your shell or add them here.

# Daytona sandbox defaults read by sst.config.ts and scripts/daytona-s3-snapshot.ts
# (the Daytona SDK reads DAYTONA_API_KEY implicitly).
# DAYTONA_ORGANIZATION_ID=
# DAYTONA_API_KEY=
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_S3_SNAPSHOT_NAME=fuse-s3
# DAYTONA_S3_SNAPSHOT_BASE_IMAGE=daytonaio/sandbox:0.8.0

# Mock webhook subscription secret for testing inbound webhooks.
# CI/CD uses the MOCK_WEBHOOK_SECRET GitHub secret.
#   MOCK_WEBHOOK_SECRET=<long-random-value>

# NATS (WebSocket transport + JetStream) for the WebSocket gateway path.
# Required when ENABLE_WEBSOCKET=true. CI/CD uses the NATS_URL / NATS_TOKEN secrets.
# Use the wss:// endpoint (core 4222 is cluster-internal); omit NATS_TOKEN for an
# unauthenticated server.
#   NATS_URL=wss://nats.beeblast.co
#   NATS_TOKEN=<token>

# Optional OPA policy decision endpoint for agent runtime authorization.
# Use localhost for a core pod sidecar, or the cluster service URL when OPA runs
# as a shared k3s service.
#   OPA_BASE_URL=http://127.0.0.1:8181
#   OPA_BASE_URL=http://opa.beeblast.svc.cluster.local:8181

# Demo scripts read their own env from `packages/demos/.env` — see
# `packages/demos/.env.example`.
