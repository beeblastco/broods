{
  "name": "@filthy-panty/demos",
  "description": "Runnable demo scripts exercising the deployed filthy-panty core API and local CLI/SDK. Each example lives in its own folder under examples/ with a scoped .env.example.",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "bunx tsc --noEmit",
    "cli": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts",
    "cli:login": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts login",
    "cli:login:dev": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts login --dashboard-url https://dashboard.dev.beeblast.co",
    "cli:login:prod": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts login --dashboard-url https://dashboard.beeblast.co",
    "cli:login:local": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts login --dashboard-url http://localhost:3000",
    "cli:diff": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts diff",
    "cli:dev": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts dev",
    "cli:deploy": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts deploy",
    "cli:run": "cd examples/cli && bun ../../../filthy-panty/src/cli/index.ts run support \"Hello from the demos package\"",
    "demo:account": "cd examples/account && bun index.ts",
    "demo:async": "cd examples/async && bun index.ts",
    "demo:cron-job": "cd examples/cron-job && bun index.ts",
    "demo:sandbox-e2b": "cd examples/sandbox-e2b && bun index.ts",
    "demo:sandbox-kubernetes-direct": "cd examples/sandbox-kubernetes-direct && bun index.ts",
    "demo:sandbox-kubernetes-persistent": "cd examples/sandbox-kubernetes-persistent && bun index.ts",
    "demo:sandbox-stateless": "cd examples/sandbox-stateless && bun index.ts",
    "demo:sandbox-vercel": "cd examples/sandbox-vercel && bun index.ts",
    "demo:sandbox-workspace-daytona": "cd examples/sandbox-workspace-daytona && bun index.ts",
    "demo:sandbox-workspace-kubernetes": "cd examples/sandbox-workspace-kubernetes && bun index.ts",
    "demo:sandbox-workspace-lambda": "cd examples/sandbox-workspace-lambda && bun index.ts",
    "demo:sandbox-workspace-override": "cd examples/sandbox-workspace-override && bun index.ts",
    "demo:skill-loads": "cd examples/skill-loads && bun index.ts",
    "demo:skills": "cd examples/skills && bun index.ts",
    "demo:stream": "cd examples/stream && bun index.ts",
    "demo:structure-output": "cd examples/structure-output && bun index.ts",
    "demo:structure-output-async": "cd examples/structure-output-async && bun index.ts",
    "demo:subagent": "cd examples/subagent && bun index.ts",
    "demo:tool-approval": "cd examples/tool-approval && bun index.ts",
    "demo:uploaded-tool-async-sse": "cd examples/uploaded-tool-async-sse && bun index.ts",
    "demo:uploaded-tool-stream": "cd examples/uploaded-tool-stream && bun index.ts",
    "demo:webhook": "cd examples/webhook && bun index.ts",
    "demo:workspace-multiple": "cd examples/workspace-multiple && bun index.ts",
    "demo:workspace-readonly": "cd examples/workspace-readonly && bun index.ts"
  },
  "dependencies": {
    "@filthy-panty/core": "workspace:*",
    "ai": "^6.0.195",
    "filthy-panty": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
