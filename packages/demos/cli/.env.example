# Env for the 'cli' demo (filthy-panty CLI + SDK login/deploy/run flow).
#
# `bun run demo:cli:login` opens a browser to authenticate via the dashboard and
# stores the token at ~/.filthy-panty/config.json (outside this repo). After that
# the other cli:* scripts use the stored token; you normally do NOT need the vars
# below unless you want to bypass the browser login.

# Override the dashboard the CLI targets (defaults to prod; login:dev/login:local override per-script).
# FILTHY_PANTY_DASHBOARD_URL=https://dashboard.dev.beeblast.co
# Non-interactive token (skips browser login when set together with the URL above).
# FILTHY_PANTY_TOKEN=
# Optional fixed local callback port for the browser login.
# FILTHY_PANTY_LOGIN_PORT=18987
