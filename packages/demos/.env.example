# Demo runtime settings. Copy to `.env` (shared) or a per-demo `.env.local`.
# Bun auto-loads `.env` then `.env.local` from the demo's own folder.

# Where the SDK sends traffic. Unset -> the SDK default host gateway.broods.app.
# Point at a locally-run core to test the container end-to-end:
#   BROODS_BASE_URL=http://localhost:3000
# (Run the core first: `cd apps/core && bun run serve`. See apps/core/.env.example.)
# For the deployed dev gateway instead: BROODS_BASE_URL=https://gateway.dev.broods.app
# BROODS_BASE_URL=http://localhost:3000

# Runtime key for the account the demo agent belongs to. `bun run dev`/`deploy`
# writes this automatically for the selected environment; set it by hand when
# pointing BROODS_BASE_URL at a local/self-hosted core.
# BROODS_API_KEY=fp_agent_...

# Deployed Function URLs the configure-* scripts target (sst deploy outputs).
# ACCOUNT_SERVICE_URL=
# AGENT_SERVICE_URL=

# Model + tool keys the demo accounts are configured with.
# GOOGLE_API_KEY=
# MINIMAX_API_KEY=
# TAVILY_API_KEY=

# Mock webhook Function URL + secret (webhook demos).
# MOCK_WEBHOOK_URL=
# MOCK_WEBHOOK_SECRET=

# Sandbox provider demos (Daytona / Vercel / E2B).
# DAYTONA_API_KEY=
# DAYTONA_ORGANIZATION_ID=
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
# E2B_API_KEY=
# E2B_TEMPLATE=

# The WebSocket demo uses the SDK default gateway host; only set this for a
# non-default or self-hosted gateway.
# BROODS_WEBSOCKET_URL=wss://gateway.broods.app

# Optional timezone for the cron-job demo.
# CRON_TIMEZONE=
